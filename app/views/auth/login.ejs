<%- include('../partials/head', { title: 'Log in' }) %>
<%- include('../partials/header') %>

<main class="main">
    <div class="auth-wrapper">
        <div class="auth-card">
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-sub">Log in to your account</p>

            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-input" type="password" id="password" name="password" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" required>
                </div>
                <button class="btn btn-primary btn-lg form-submit" type="submit">Log in</button>
            </form>

            <p class="auth-footer">Don't have an account? <a href="/auth/signup">Sign up</a></p>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
