<%- include('../partials/head', { title: 'Sign up' }) %>
<%- include('../partials/header') %>

<main class="main">
    <div class="auth-wrapper">
        <div class="auth-card">
            <h1 class="auth-title">Create account</h1>
            <p class="auth-sub">Get started for free</p>

            <form action="/auth/signup" method="POST">
                <div class="form-group">
                    <label class="form-label" for="name">Name</label>
                    <input class="form-input" type="text" id="name" name="name" placeholder="John Doe" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-input" type="password" id="password" name="password" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" required>
                </div>
                <button class="btn btn-primary btn-lg form-submit" type="submit">Create account</button>
            </form>

            <p class="auth-footer">Already have an account? <a href="/auth/login">Log in</a></p>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
